// RushDesk — Prisma schema
// Database provider: Supabase (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id            String   @id @default(cuid())
  name          String
  googlePlaceId String?  @unique
  // When true, orders placed through the AI voice receptionist are not
  // emitted to the kitchen dashboard until the caller completes a Stripe
  // Checkout payment whose URL is SMSed to them. This is an anti-no-show
  // measure: staff only prepare food that has already been paid for.
  // Non-voice orders (WEB / STAFF) are unaffected by this toggle.
  requireVoicePaymentUpfront Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  menuItems     MenuItem[]
  orders        Order[]
  reservations  Reservation[]
}

model MenuItem {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  category   String?
  price      Decimal  @db.Decimal(10, 2)
  available  Boolean  @default(true)
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orderItems OrderItem[]

  @@index([businessId, category])
  @@index([businessId, available])
}

model Order {
  id            String      @id @default(cuid())
  businessId    String
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName  String?
  customerPhone String?
  type          OrderType   @default(DINE_IN)
  status        OrderStatus @default(PENDING)
  source        OrderSource @default(VOICE)
  // Server-computed from sum(OrderItem.unitPrice * quantity).
  // Never trust a client-submitted total.
  totalAmount   Decimal     @db.Decimal(10, 2)
  notes         String?
  // Idempotency key supplied by the caller (e.g. the voice-agent's call SID)
  // to make order creation safe under retries. Scoped per-business.
  idempotencyKey String?
  // Advance-payment tracking for voice orders where the business requires
  // payment before the order reaches the kitchen. For WEB / STAFF orders
  // and for voice orders when the toggle is off, `paymentStatus` is
  // `NOT_REQUIRED` and the payment fields are null.
  paymentStatus    PaymentStatus @default(NOT_REQUIRED)
  // Stripe Checkout Session id. Unique so the webhook can find exactly
  // one order per session and so a retry can't bind two orders to the
  // same session.
  stripeSessionId  String?       @unique
  // Hosted Stripe Checkout URL that was SMSed to the caller. Retained so
  // staff can re-surface the link if the SMS was missed.
  paymentUrl       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items         OrderItem[]

  @@unique([businessId, idempotencyKey])
  @@index([businessId, status])
  @@index([businessId, createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int      @default(1)
  // Snapshot of MenuItem.price at order time — the menu price can
  // change after the order is placed.
  unitPrice  Decimal  @db.Decimal(10, 2)
  // Per-line special instructions captured by the voice agent, e.g.
  // "no onions", "extra ranch", "gluten-free bun". Bounded length is
  // enforced at the validation layer.
  notes      String?

  @@index([orderId])
}

model Reservation {
  id            String            @id @default(cuid())
  businessId    String
  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String?
  customerEmail String?
  partySize     Int
  date          DateTime
  status        ReservationStatus @default(PENDING)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([businessId, date])
  @@index([businessId, status])
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderSource {
  VOICE
  WEB
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

// Lifecycle of an order's advance-payment requirement. Only voice orders
// placed while the business's `requireVoicePaymentUpfront` flag is on
// ever enter `PENDING`; the Stripe webhook drives the transition to
// `PAID` (which triggers the kitchen publish) or `EXPIRED` (which
// auto-cancels the order).
enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  EXPIRED
  FAILED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}
