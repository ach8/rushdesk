# Database (Supabase Postgres connection string)
DATABASE_URL="postgresql://user:password@host:5432/rushdesk?schema=public"

# OpenAI
OPENAI_API_KEY="sk-your-openai-key-here"
OPENAI_MODEL="gpt-4o-mini"

# Shared secret for admin-only API endpoints.
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN="replace-with-a-long-random-string-at-least-32-chars"

# Supabase (public client)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Distributed pub/sub for the kitchen dashboard SSE stream AND voice-call
# session state (per-call transcript persisted across webhook invocations).
# REQUIRED on Vercel / any horizontally-scaled deploy — without it an
# event published on container A will not reach an SSE subscriber pinned
# to container B, and a voice turn hitting a cold container will lose
# the conversation-so-far. Upstash Redis is the recommended provider.
# Leave unset for local dev / single-node deploys; the app falls back to
# in-process EventEmitter + Map.
REDIS_URL="rediss://default:<password>@<region>.upstash.io:6379"

# ───────────────────────────────────────────────────────────────────────
# AI Voice Receptionist (Twilio + OpenAI)
# ───────────────────────────────────────────────────────────────────────
# Twilio account credentials. The Auth Token validates every inbound
# webhook signature — without it any caller on the internet could POST
# fake TwiML payloads to our voice endpoints and inject orders.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"

# Public origin Twilio calls back into. Must match the "A call comes in"
# webhook URL configured on your Twilio phone number, exactly — this is
# what the HMAC signature is computed against.
PUBLIC_BASE_URL="https://rushdesk.example.com"

# Neural TTS voice + language. See Twilio docs for the full catalog.
#   Good choices: Polly.Joanna-Neural, Polly.Matthew-Neural, Google.en-US-Neural2-F
TWILIO_VOICE="Polly.Joanna-Neural"
TWILIO_LANGUAGE="en-US"
