# Database (Supabase Postgres connection string)
DATABASE_URL="postgresql://user:password@host:5432/rushdesk?schema=public"

# OpenAI
OPENAI_API_KEY="sk-your-openai-key-here"
OPENAI_MODEL="gpt-4o-mini"

# Shared secret for admin-only API endpoints.
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN="replace-with-a-long-random-string-at-least-32-chars"

# Supabase (public client)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Distributed pub/sub for the kitchen dashboard SSE stream.
# REQUIRED on Vercel / any horizontally-scaled deploy — without it an
# event published on container A will not reach an SSE subscriber pinned
# to container B. Upstash Redis is the recommended provider.
# Leave unset for local dev / single-node deploys; the app falls back to
# an in-process EventEmitter.
REDIS_URL="rediss://default:<password>@<region>.upstash.io:6379"

# ───────────────────────────────────────────────────────────────────────
# AI Voice Receptionist (ElevenLabs Conversational AI)
# ───────────────────────────────────────────────────────────────────────
# Shared secret ElevenLabs signs outbound server-tool webhooks with
# (HMAC-SHA256, `ElevenLabs-Signature` header). Generated in the
# ElevenLabs dashboard under Webhooks. Without it any caller on the
# internet could POST fake order payloads to /api/voice/submit-order.
ELEVENLABS_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Anti-abuse: max submit_order attempts per caller phone number per
# rolling 24h window. The next attempt is denied and the agent tells the
# caller they've hit the daily limit.
VOICE_ORDER_DAILY_LIMIT="2"

# ───────────────────────────────────────────────────────────────────────
# Advance payment for voice orders (anti-no-show)
# ───────────────────────────────────────────────────────────────────────
# These are only consulted when a business flips on the
# `requireVoicePaymentUpfront` toggle in /admin/settings. If the toggle
# is OFF for every business, RushDesk runs fine with all of these unset.
#
# Stripe — receives the charge; hosts the Checkout page we link to in SMS.
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Set from the Stripe dashboard webhook endpoint created for
# /api/stripe/webhook. Used to verify inbound webhook signatures.
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Twilio — sends the SMS that contains the Stripe Checkout URL.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# E.164 phone number or a Messaging Service SID (MGxxxxxxxx...).
TWILIO_FROM_NUMBER="+15551234567"

# Public origin of this deployment. Used to build Stripe Checkout
# success/cancel URLs — no trailing slash.
APP_BASE_URL="https://rushdesk.example.com"

# How long (in minutes) a voice-order Stripe Checkout Session remains
# payable. Keep this short — longer windows leave abandoned orders
# dangling as PENDING in the DB, irritating kitchen staff. Stripe's own
# minimum is 30 and maximum is 1440 (24h); we clamp to that range.
# Pair with the /api/orders/sweep-payments cron for belt-and-suspenders
# cleanup if a Stripe webhook delivery is missed.
VOICE_PAYMENT_SESSION_TTL_MINUTES="30"
